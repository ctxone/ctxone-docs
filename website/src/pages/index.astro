---
/**
 * The landing page at ctxone.com/
 *
 * Composes the five main sections: hero, problem, feature grid,
 * savings showcase, integrations, final CTA.
 */
import LandingLayout from '../layouts/LandingLayout.astro';
import Hero from '../components/Hero.astro';
import ProblemSection from '../components/ProblemSection.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import PlansSection from '../components/PlansSection.astro';
import TokenControlSection from '../components/TokenControlSection.astro';
import IntegrationsRow from '../components/IntegrationsRow.astro';
import MultiModelSection from '../components/MultiModelSection.astro';
import CallToAction from '../components/CallToAction.astro';
---

<LandingLayout
	title="CTXone — external context for AI agents"
	description="System-centric AI infrastructure. Persistent memory, structured plans, and full provenance — so models execute within context instead of reasoning their way back to it."
>
	<Hero />
	<ProblemSection />
	<FeatureGrid />
	<PlansSection />
	<TokenControlSection />
	<IntegrationsRow />
	<MultiModelSection />
	<CallToAction />
</LandingLayout>
